generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  name               String
  role               Role                @default(OPERATOR)
  password           String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  maintenanceLogs    Maintenance[]
  vehicleMovements   VehicleMovement[]
}

model Cedis {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique
  client             String?
  location           String?
  latitude           Float?
  longitude          Float?
  inventoryMovements InventoryMovement[]
  inventoryStock     InventoryStock[]
  providers          Provider[]
  currentVehicles    Vehicle[]           @relation("VehicleLocation")
  vehicleDepartures  VehicleMovement[]   @relation("FromCedis")
  vehicleArrivals    VehicleMovement[]   @relation("ToCedis")
}

model Vehicle {
  id              Int               @id @default(autoincrement())
  plate           String            @unique
  truckNumber     String            @unique
  status          VehicleStatus     @default(ACTIVE)
  engine          String?
  yearModel       Int?
  transmission    String?
  fuelType        String?
  vin             String?           @unique
  currentCedisId  Int?
  brandId         Int?
  fuelTypeId      Int?
  transmissionId  Int?
  maintenanceLogs Maintenance[]
  partExchanges   PartExchange[]
  tireRotations   TireRotation[]
  brand           VehicleBrand?     @relation(fields: [brandId], references: [id])
  currentCedis    Cedis?            @relation("VehicleLocation", fields: [currentCedisId], references: [id])
  fuelTypeRel     FuelType?         @relation(fields: [fuelTypeId], references: [id])
  transmissionRel TransmissionType? @relation(fields: [transmissionId], references: [id])
  documents       VehicleDocument[]
  movementHistory VehicleMovement[]
  faults          Fault[]

  @@index([brandId], map: "Vehicle_brandId_fkey")
  @@index([currentCedisId], map: "Vehicle_currentCedisId_fkey")
  @@index([fuelTypeId], map: "Vehicle_fuelTypeId_fkey")
  @@index([transmissionId], map: "Vehicle_transmissionId_fkey")
}

model VehicleMovement {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  fromCedisId Int?
  toCedisId   Int
  date        DateTime @default(now())
  userId      Int
  reason      String?
  fromCedis   Cedis?   @relation("FromCedis", fields: [fromCedisId], references: [id])
  toCedis     Cedis    @relation("ToCedis", fields: [toCedisId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  vehicle     Vehicle                   @relation(fields: [vehicleId], references: [id])
  evidence    VehicleMovementEvidence[]

  @@index([vehicleId], map: "VehicleMovement_vehicleId_fkey")
}

model VehicleMovementEvidence {
  id         Int             @id @default(autoincrement())
  movementId Int
  url        String
  createdAt  DateTime        @default(now())
  movement   VehicleMovement @relation(fields: [movementId], references: [id])

  @@index([movementId], map: "VehicleMovementEvidence_movementId_fkey")
}

model DocumentType {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  alertDays   Int?
  documents   VehicleDocument[]
}

model VehicleDocument {
  id         Int                       @id @default(autoincrement())
  vehicleId  Int
  typeId     Int
  issueDate  DateTime
  expiryDate DateTime
  status     DocumentStatus            @default(PENDING)
  type       DocumentType              @relation(fields: [typeId], references: [id])
  vehicle    Vehicle                   @relation(fields: [vehicleId], references: [id])
  evidence   VehicleDocumentEvidence[]

  @@index([typeId], map: "VehicleDocument_typeId_fkey")
  @@index([vehicleId], map: "VehicleDocument_vehicleId_fkey")
}

model VehicleDocumentEvidence {
  id         Int             @id @default(autoincrement())
  documentId Int
  url        String
  createdAt  DateTime        @default(now())
  document   VehicleDocument @relation(fields: [documentId], references: [id])

  @@index([documentId], map: "VehicleDocumentEvidence_documentId_fkey")
}

model Maintenance {
  id             Int                   @id @default(autoincrement())
  vehicleId      Int
  type           MaintenanceType
  description    String
  date           DateTime              @default(now())
  userId         Int?
  providerId     Int?
  status         MaintenanceStatus     @default(SCHEDULED)
  provider       Provider?             @relation(fields: [providerId], references: [id])
  user           User?                 @relation(fields: [userId], references: [id])
  vehicle        Vehicle               @relation(fields: [vehicleId], references: [id])
  evidence       MaintenanceEvidence[]
  parts          MaintenancePart[]
  tickets        MaintenanceTicket[]
  faultsResolved Fault[]

  @@index([providerId], map: "Maintenance_providerId_fkey")
  @@index([userId], map: "Maintenance_userId_fkey")
  @@index([vehicleId], map: "Maintenance_vehicleId_fkey")
}

model MaintenanceTicket {
  id            Int                     @id @default(autoincrement())
  maintenanceId Int
  ticketNumber  String
  cost          Decimal
  date          DateTime                @default(now())
  maintenance   Maintenance             @relation(fields: [maintenanceId], references: [id])
  items         MaintenanceTicketItem[]

  @@index([maintenanceId], map: "MaintenanceTicket_maintenanceId_fkey")
}

model MaintenanceTicketItem {
  id          Int               @id @default(autoincrement())
  ticketId    Int
  description String
  cost        Decimal
  ticket      MaintenanceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId], map: "MaintenanceTicketItem_ticketId_fkey")
}

model Fault {
  id            Int           @id @default(autoincrement())
  vehicleId     Int
  description   String        @db.Text
  severity      FaultSeverity @default(MEDIUM)
  status        FaultStatus   @default(PENDING)
  reportedAt    DateTime      @default(now())
  resolvedAt    DateTime?
  maintenanceId Int?

  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id])
  maintenance Maintenance?     @relation(fields: [maintenanceId], references: [id])
  evidence    FaultEvidence[]

  @@index([vehicleId], map: "Fault_vehicleId_fkey")
  @@index([maintenanceId], map: "Fault_maintenanceId_fkey")
}

model FaultEvidence {
  id        Int      @id @default(autoincrement())
  faultId   Int
  url       String
  createdAt DateTime @default(now())
  fault     Fault    @relation(fields: [faultId], references: [id])

  @@index([faultId], map: "FaultEvidence_faultId_fkey")
}

enum FaultSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FaultStatus {
  PENDING
  RESOLVED
}

model MaintenancePart {
  id            Int         @id @default(autoincrement())
  maintenanceId Int
  productId     Int
  quantity      Int         @default(1)
  unitCost      Decimal?
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])

  @@index([maintenanceId], map: "MaintenancePart_maintenanceId_fkey")
  @@index([productId], map: "MaintenancePart_productId_fkey")
}

model MaintenanceEvidence {
  id            Int         @id @default(autoincrement())
  maintenanceId Int
  url           String
  createdAt     DateTime    @default(now())
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id])

  @@index([maintenanceId], map: "MaintenanceEvidence_maintenanceId_fkey")
}

model Provider {
  id           Int           @id @default(autoincrement())
  name         String
  contact      String?
  services     String?
  cedisId      Int?
  maintenances Maintenance[]
  cedis        Cedis?        @relation(fields: [cedisId], references: [id])

  @@index([cedisId], map: "Provider_cedisId_fkey")
}

model Product {
  id               Int                 @id @default(autoincrement())
  name             String
  code             String              @unique
  description      String?
  category         String
  movements        InventoryMovement[]
  stock            InventoryStock[]
  maintenanceParts MaintenancePart[]
  partExchanges    PartExchange[]
}

model InventoryStock {
  id        Int     @id @default(autoincrement())
  cedisId   Int
  productId Int
  quantity  Int     @default(0)
  cedis     Cedis   @relation(fields: [cedisId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cedisId, productId])
  @@index([productId], map: "InventoryStock_productId_fkey")
}

model InventoryMovement {
  id        Int                         @id @default(autoincrement())
  cedisId   Int
  productId Int
  type      InventoryStartType
  quantity  Int
  unitPrice Decimal?
  totalCost Decimal?
  date      DateTime                    @default(now())
  userId    Int?
  notes     String?
  cedis     Cedis                       @relation(fields: [cedisId], references: [id])
  product   Product                     @relation(fields: [productId], references: [id])
  user      User?                       @relation(fields: [userId], references: [id])
  evidence  InventoryMovementEvidence[]

  @@index([cedisId], map: "InventoryMovement_cedisId_fkey")
  @@index([productId], map: "InventoryMovement_productId_fkey")
  @@index([userId], map: "InventoryMovement_userId_fkey")
}

model InventoryMovementEvidence {
  id         Int               @id @default(autoincrement())
  movementId Int
  url        String
  createdAt  DateTime          @default(now())
  movement   InventoryMovement @relation(fields: [movementId], references: [id])

  @@index([movementId], map: "InventoryMovementEvidence_movementId_fkey")
}

model TireRotation {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  date        DateTime @default(now())
  description String
  mileage     Int?
  positionMap Json?
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId], map: "TireRotation_vehicleId_fkey")
}

model PartExchange {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  productId   Int
  action      String
  quantity    Int      @default(1)
  date        DateTime @default(now())
  description String
  product     Product  @relation(fields: [productId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([productId], map: "PartExchange_productId_fkey")
  @@index([vehicleId], map: "PartExchange_vehicleId_fkey")
}

model VehicleBrand {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  vehicles Vehicle[]
}

model TransmissionType {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  vehicles Vehicle[]
}

model FuelType {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  vehicles Vehicle[]
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
}

enum InventoryStartType {
  PURCHASE
  TRANSFER_IN
  TRANSFER_OUT
  USAGE
  LOSS
  ADJUSTMENT
}

enum Role {
  ADMIN
  OPERATOR
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  IN_TRANSIT
}

enum DocumentStatus {
  VALID
  EXPIRED
  PENDING
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
